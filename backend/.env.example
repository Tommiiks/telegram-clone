# Copia questo file come .env e compila i valori reali.
# NON committare il file .env — contiene credenziali.

# Qualsiasi stringa lunga e casuale (es. 64 caratteri hex)
JWT_SECRET=cambia_questo_con_una_stringa_segreta_molto_lunga_12345678

# Gmail: usa un App Password (NON la tua password normale).
# Vai su: Account Google > Sicurezza > Verifica in due passaggi > Password per le app
MAIL_USERNAME=tuaemail@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
